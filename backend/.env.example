# Postgres connection (psycopg v3 driver)
DATABASE_URL=postgresql+psycopg://poker:poker@localhost:5432/poker_mtt

# Auth — generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false   # set true behind HTTPS in production

DEBUG=false
